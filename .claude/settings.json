{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npm run test*)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "echo '--- CONTEXTE finance-pwa ---' && git log --oneline -5 2>/dev/null && git status --short 2>/dev/null"
      }
    ]
  },
  "enableAllProjectMcpServers": true
}
