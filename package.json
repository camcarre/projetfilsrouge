{
  "name": "finance-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PWA Visualisation Financière et Recommandations ETF",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n back,front -c blue,green \"cd backend && uvicorn main:app --reload --port 3000\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src vite.config.ts --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "gsap": "^3.14.2",
    "preact": "^10.24.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.0",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript-eslint": "^8.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^0.19.0",
    "vitest": "^2.0.0"
  }
}
